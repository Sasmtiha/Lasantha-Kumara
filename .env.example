# PostgreSQL connection string (local Postgres, Supabase Postgres, Neon, etc.)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/lasantha_english

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Supabase Storage for Payload CMS uploads
# Project ref is the first subdomain in https://<project-ref>.supabase.co
SUPABASE_PROJECT_REF=YOUR_SUPABASE_PROJECT_REF
SUPABASE_STORAGE_BUCKET=media
SUPABASE_STORAGE_REGION=us-east-1
SUPABASE_STORAGE_ACCESS_KEY_ID=YOUR_SUPABASE_STORAGE_S3_ACCESS_KEY_ID
SUPABASE_STORAGE_SECRET_ACCESS_KEY=YOUR_SUPABASE_STORAGE_S3_SECRET_ACCESS_KEY

# SMTP Email Configuration (Gmail, Resend, etc. for Contact Form Submissions)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com
CONTACT_RECEIVER_EMAIL=iem.lasantha@gmail.com
